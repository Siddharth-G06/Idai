# Vaakazhipeer Backend Environment Variables

# Groq API Key for LLM Verification
GROQ_API_KEY=your_groq_api_key_here

# NewsAPI Key for Historical Data (optional)
NEWSAPI_KEY=your_newsapi_key_here

# CORS Allowed Origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Port (Render/Railway will set this automatically)
PORT=8000
